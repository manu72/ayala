# API Keys
OPENAI_API_KEY=your_openai_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
TAVILY_API_KEY=your_tavily_api_key_here
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here
INCEPTION_API_KEY=your_inception_api_key_here

# LLM Failover (transparent per-request retry with alternate provider)
LLM_FAILOVER_ENABLED=true
OPENAI_FAILOVER_MODEL=deepseek-chat
DEEPSEEK_FAILOVER_MODEL=gpt-4.1-mini
INCEPTION_FAILOVER_MODEL=gpt-4.1-mini
LLM_CIRCUIT_FAILURE_THRESHOLD=3
LLM_CIRCUIT_RECOVERY_TIMEOUT_S=300
LLM_FAILOVER_EMAIL_COOLDOWN_S=900

# Optional: Organization ID for OpenAI
OPENAI_ORG_ID=your_openai_org_id_here